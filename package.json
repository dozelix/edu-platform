{
  "name": "EduPlataform",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://dozelix.github.io/edu-plataform",
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "vite --config packages/frontend/vite.config.js",
    "dev:main": "cross-env NODE_ENV=development electron packages/main/src/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "build:main": "echo 'Main process does not require transpilation'",
    "build:frontend": "vite build --config packages/frontend/vite.config.js",
    "build": "npm run build:frontend",
    "electron": "cross-env NODE_ENV=production electron packages/main/src/index.js",
    "electron:dev": "concurrently \"npm run dev:frontend\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron packages/main/src/index.js\"",
    "shot": "concurrently -k -s first \"npm run dev:frontend\" \"wait-on http://localhost:5173 && node scripts/shot-electron.cjs\"",
    "lint": "eslint \"packages/*/src/**/*.{js,cjs,jsx}\" \"scripts/**/*.{js,cjs}\"",
    "eslint": "npm run lint",
    "format": "prettier --write \"packages/*/src/**/*.{js,cjs,jsx,json,css}\"",
    "test": "vitest",
    "predeploy": "vite build --config packages/frontend/vite.config.js --outDir ../../dist-gh",
    "deploy": "gh-pages -d dist-gh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.2",
    "eslint": "^10.5.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "mongoose": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.eduplatform.app",
    "productName": "EduPlatform",
    "directories": {
      "output": "release"
    },
    "files": [
      "packages/main/src/**/*",
      "packages/frontend/dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "packages/main/src/index.js"
    }
  }
}
